## === Build ===

## --- Gradle ---

# ignore Gradle project-specific cache directories
.gradle/

# ignore Gradle build output directories
build/

# ignore Gradle local propertiers
/local.properties

# ignore Gradle daemon JVM toolchain metadata (generated by IDE/Gradle)
gradle/gradle-daemon-jvm.properties

## --- Kotlin ---

# ignore Kotlin project-specific cache directories
.kotlin/


## === IDEs ===

## --- AndroidStudio ---

# ignore AndroidStudio files
/.idea/*
!/.idea/icon.png
*.iml
/captures/

## --- Xcode ---

# ignore Xcode project
app/iosApp/iosApp.xcodeproj/*
!app/iosApp/iosApp.xcodeproj/project.pbxproj

# ignore Xcode build artifacts
DerivedData/
*.xcarchive

# ignore Xcode user-specific files
xcuserdata/
*.xcuserstate


## === OS specific ===

## --- MacOS ---

# ignore MacOS prefs folders
.DS_Store
